---
import "../../styles/global.css";
import { profile } from "@/data/portfolio";
import type { AstroComponentFactory } from "astro/runtime/server/index.js";

type DayFrontmatter = {
  day: number;
  title: string;
  action: string;
  outcome: string;
  fear: string;
  lesson: string;
  mood?: string;
  linkedIn?: string;
  x?: string;
  youtube?: string;
};

type DayModule = {
  default: AstroComponentFactory;
  frontmatter: DayFrontmatter;
};

export const prerender = true;

export function getStaticPaths() {
  const modules = import.meta.glob<DayModule>("../../content/days/*.mdx", { eager: true });
  return Object.entries(modules).map(([path, entry]) => ({
    params: { slug: path.split("/").pop()?.replace(".mdx", "") },
    props: { entry },
  }));
}

const { entry } = Astro.props as { entry: DayModule };
const Content = entry.default;
const day = entry.frontmatter;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={`${profile.name} - Day ${day.day}: ${day.title}`} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <title>Day {day.day}: {day.title} - {profile.name}</title>
  </head>
  <body>
    <main class="day-page">
      <header class="day-hero">
        <a href="/100-days" class="journey-back">Back to 100 Days</a>
        <p class="eyebrow">Day {day.day} / {day.fear}</p>
        <h1>{day.title}</h1>
        <div class="day-summary">
          <div>
            <span>Did</span>
            <p>{day.action}</p>
          </div>
          <div>
            <span>Overcame</span>
            <p>{day.outcome}</p>
          </div>
          <div>
            <span>Learned</span>
            <p>{day.lesson}</p>
          </div>
        </div>
        <div class="social-links day-socials">
          {day.linkedIn && <a href={day.linkedIn} target="_blank" rel="noreferrer">LinkedIn</a>}
          {day.x && <a href={day.x} target="_blank" rel="noreferrer">X</a>}
          {day.youtube && <a href={day.youtube} target="_blank" rel="noreferrer">YouTube</a>}
        </div>
      </header>

      <article class="day-content">
        <Content />
      </article>
    </main>
  </body>
</html>

<style is:global>
  body {
    overflow: auto;
  }

  .day-page {
    width: min(860px, calc(100% - 32px));
    margin: 0 auto;
    padding: 36px 0 76px;
  }

  .day-hero {
    border-bottom: 1px solid var(--line);
    padding-bottom: 24px;
    margin-bottom: 28px;
  }

  .journey-back {
    display: inline-flex;
    margin-bottom: 22px;
    border: 1px solid var(--ink);
    border-radius: var(--radius);
    padding: 9px 11px;
    background: var(--surface);
    font-size: 0.84rem;
    font-weight: 850;
    box-shadow: 4px 4px 0 var(--orange);
  }

  .day-hero h1 {
    margin: 0 0 18px;
    font-size: clamp(2.8rem, 7vw, 6rem);
    line-height: 0.92;
  }

  .day-summary {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
  }

  .day-summary div {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 13px;
    background: rgba(255, 250, 241, 0.78);
  }

  .day-summary span {
    color: var(--muted);
    font-size: 0.72rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .day-summary p {
    margin: 8px 0 0;
    font-weight: 780;
    line-height: 1.3;
  }

  .day-socials {
    margin-top: 12px;
  }

  .day-content {
    font-size: 1.04rem;
    line-height: 1.68;
  }

  .day-content h2 {
    margin-top: 34px;
    font-size: 1.7rem;
    line-height: 1.1;
  }

  .day-content p,
  .day-content li {
    color: var(--muted);
  }

  .day-content blockquote {
    border-left: 4px solid var(--orange);
    margin-left: 0;
    padding-left: 16px;
    font-weight: 760;
  }

  @media (max-width: 760px) {
    .day-summary {
      grid-template-columns: 1fr;
    }
  }
</style>
